# 复制为 .env 后按需修改：
#   cp .env.example .env

# 镜像 tag（对应 ghcr.io/micah123321/tg-signer:<tag> 与 <tag>-webui）
# 常用: latest | main | v0.9.0
# 计划调度需镜像内含 serve 命令（main / 新版 release）；过旧 tag 请升级
TG_IMAGE_TAG=latest

# 调度时区
TZ=Asia/Shanghai

# Telegram 默认代理（账号页可再为每个账号单独覆盖）
# Linux 访问宿主机代理常见: socks5://172.17.0.1:7890
# Docker Desktop (Windows/macOS): socks5://host.docker.internal:7890
TG_PROXY=

# 默认账号名（CLI login 未传 -a 时使用）；多账号请多次 login -a
TG_ACCOUNT=my_account

# 可选：直接注入 session string
# TG_SESSION_STRING=

# WebUI 授权码（务必修改）
TG_SIGNER_GUI_AUTHCODE=change-me

# WebUI 宿主机端口
WEBUI_PORT=8080

# serve 执行签到时拉取最近对话数
TG_NUM_OF_DIALOGS=50

# 仅 legacy-run profile 使用：单任务 CLI 常驻的任务名
# TG_SIGN_TASK=my_sign

# 可选：AI 能力（识图、计算题等）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
