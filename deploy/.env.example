# 复制为 .env 后按需修改：
#   cp .env.example .env

# =============================================================================
# 镜像来源（二选一，改下面三行即可）
# =============================================================================
#
# --- A) GHCR 预构建（默认，主机不必有完整源码也能 pull）---
TG_IMAGE_REGISTRY=ghcr.io/micah123321/tg-signer
TG_IMAGE_TAG=latest
# missing=本地没有才拉；always=每次 up 都尝试 pull
TG_PULL_POLICY=missing
# 更新预构建：
#   docker compose pull
#   docker compose up -d
#
# --- B) 本地源码编译（需在 git 仓库内；改代码/git pull 后重建）---
# 将上面三行改成：
#   TG_IMAGE_REGISTRY=tg-signer
#   TG_IMAGE_TAG=local
#   TG_PULL_POLICY=build
# 更新本地编译：
#   cd .. && git pull && cd deploy
#   docker compose up -d --build --force-recreate
#
# 说明：
#   WebUI 镜像 = ${TG_IMAGE_REGISTRY}:${TG_IMAGE_TAG}-webui
#   CLI 镜像   = ${TG_IMAGE_REGISTRY}:${TG_IMAGE_TAG}
#   本地 build 使用仓库根目录 docker/GHCR.Dockerfile（target: webui / cli）
# 计划调度需镜像内含 serve（main / 新版 release）；过旧 tag 请升级

# =============================================================================
# 运行参数
# =============================================================================

# 调度时区
TZ=Asia/Shanghai

# Telegram 默认代理（账号页可再为每个账号单独覆盖）
# Linux 访问宿主机代理常见: socks5://172.17.0.1:7890
# Docker Desktop (Windows/macOS): socks5://host.docker.internal:7890
TG_PROXY=

# 默认账号名（CLI login 未传 -a 时使用）；多账号请多次 login -a
TG_ACCOUNT=my_account

# 可选：直接注入 session string
# TG_SESSION_STRING=

# WebUI 授权码（务必修改）
TG_SIGNER_GUI_AUTHCODE=change-me

# WebUI 宿主机端口
WEBUI_PORT=8080

# serve 执行签到时拉取最近对话数
TG_NUM_OF_DIALOGS=50

# 仅 legacy-run profile 使用：单任务 CLI 常驻的任务名
# TG_SIGN_TASK=my_sign

# 可选：AI 能力（识图、计算题等）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
