# 复制为 .env 后按需修改：
#   cp .env.example .env

# 镜像 tag（对应 ghcr.io/micah123321/tg-signer:<tag> 与 <tag>-webui）
# 常用: latest | main | v0.9.0
TG_IMAGE_TAG=latest

# 调度时区（未设置时容器内回退本地时区，再回退 Asia/Shanghai）
TZ=Asia/Shanghai

# Telegram 代理（不需要则留空）
# Linux 访问宿主机代理常见: socks5://172.17.0.1:7890
# Docker Desktop (Windows/macOS): socks5://host.docker.internal:7890
TG_PROXY=

# 账号名 / session 文件名（默认 my_account → data/my_account.session）
TG_ACCOUNT=my_account

# 可选：直接注入 session string（一般用 login 生成 session 文件即可）
# TG_SESSION_STRING=

# 常驻签到任务名（需先配置存在，见 README）
TG_SIGN_TASK=my_sign

# WebUI 授权码（务必修改）
TG_SIGNER_GUI_AUTHCODE=change-me

# WebUI 宿主机端口
WEBUI_PORT=8080

# 可选：AI 能力（识图、计算题等）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
